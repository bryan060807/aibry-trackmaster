{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "node server/index.js",
    "dev:api:split": "npm --prefix trackmaster-api run dev",
    "start:windows-readiness": "powershell -ExecutionPolicy Bypass -File scripts/start-windows-readiness.ps1",
    "check:api": "node --check server/index.js && npm --prefix trackmaster-api run check && node --check scripts/postgres-rehearsal.mjs && node --check scripts/api-read-validation.mjs && node --check scripts/api-write-validation.mjs && node --check scripts/backend-switch-preflight.mjs && node --check scripts/backend-switch-report.mjs && node --check scripts/production-cutover-preflight.mjs && node --check scripts/production-cutover-report.mjs && node --check scripts/trackmaster-fedora-readiness-report.mjs && node --check scripts/trackmaster-storage-preflight.mjs && node --check scripts/trackmaster-backup-preflight.mjs && node --check scripts/trackmaster-cutover-no-go-report.mjs",
    "test:api": "npm --prefix trackmaster-api test",
    "pm2:windows-readiness:start": "pm2 start ecosystem.windows-readiness.config.cjs --update-env",
    "pm2:windows-readiness:stop": "pm2 stop trackmaster-windows-readiness-api",
    "pm2:windows-readiness:delete": "pm2 delete trackmaster-windows-readiness-api",
    "pm2:windows-readiness:status": "pm2 status trackmaster-windows-readiness-api",
    "pm2:windows-readiness:logs": "pm2 logs trackmaster-windows-readiness-api --lines 80",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit && npm run check:api",
    "migration:dry-run": "node scripts/postgres-rehearsal.mjs --dry-run",
    "migration:rehearsal": "node scripts/postgres-rehearsal.mjs --apply --reset",
    "validate:api:reads": "node scripts/api-read-validation.mjs",
    "validate:api:writes": "node scripts/api-write-validation.mjs",
    "backend-switch:preflight": "node scripts/backend-switch-preflight.mjs",
    "backend-switch:report": "node scripts/backend-switch-report.mjs",
    "production-cutover:preflight": "node scripts/production-cutover-preflight.mjs",
    "production-cutover:report": "node scripts/production-cutover-report.mjs",
    "fedora:readiness": "node scripts/trackmaster-fedora-readiness-report.mjs",
    "fedora:storage-preflight": "node scripts/trackmaster-storage-preflight.mjs",
    "fedora:backup-preflight": "node scripts/trackmaster-backup-preflight.mjs",
    "fedora:cutover-no-go": "node scripts/trackmaster-cutover-no-go-report.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "lamejs": "^1.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
