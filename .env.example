PORT=3004
TRACKMASTER_HOST=127.0.0.1
TRACKMASTER_DATA_DIR=./data
TRACKMASTER_UPLOAD_LIMIT=120mb
TRACKMASTER_REPOSITORY_BACKEND=sqlite
# Future runtime cutover only. Keep production on sqlite until the migration
# runbook is approved and final import validation passes.
# TRACKMASTER_POSTGRES_URL=postgres://trackmaster:trackmaster@127.0.0.1:5432/trackmaster
# TRACKMASTER_POSTGRES_POOL_MAX=5
# Test-only contract harness. This drops and recreates TrackMaster tables.
# TRACKMASTER_TEST_POSTGRES_URL=postgres://trackmaster:trackmaster@127.0.0.1:5432/trackmaster_test
# TRACKMASTER_TEST_POSTGRES_RESET=1
# Migration preview/import tooling. Dry-run is default; import requires --apply
# plus TRACKMASTER_MIGRATION_ALLOW_WRITE=1.
# TRACKMASTER_MIGRATION_SQLITE_PATH=./data/trackmaster.sqlite
# TRACKMASTER_MIGRATION_POSTGRES_URL=postgres://trackmaster:trackmaster@127.0.0.1:5432/trackmaster_test
# TRACKMASTER_MIGRATION_ALLOW_WRITE=0
# Fedora-style rehearsal wrapper. Preview is default; import requires --apply
# plus TRACKMASTER_REHEARSAL_ALLOW_WRITE=1.
# TRACKMASTER_REHEARSAL_SQLITE_PATH=./data/trackmaster.sqlite
# TRACKMASTER_REHEARSAL_POSTGRES_URL=postgres://trackmaster:trackmaster@127.0.0.1:5432/trackmaster_test
# TRACKMASTER_REHEARSAL_ALLOW_WRITE=0
# TRACKMASTER_REHEARSAL_API_JWT_SECRET=trackmaster-rehearsal-secret-32-chars
# Real server process validation against disposable imported Postgres. Read-only
# smoke tests only; requires TRACKMASTER_STAGING_ALLOW_RUNTIME_VALIDATION=1.
# TRACKMASTER_STAGING_POSTGRES_URL=postgres://trackmaster:trackmaster@127.0.0.1:5432/trackmaster_rehearsal
# TRACKMASTER_STAGING_DATA_DIR=./data
# TRACKMASTER_STAGING_OUT_DIR=./trackmaster-api/reports/postgres-runtime-validations/manual
# TRACKMASTER_STAGING_API_JWT_SECRET=trackmaster-staging-secret-32-characters
# TRACKMASTER_STAGING_POSTGRES_POOL_MAX=2
# TRACKMASTER_STAGING_ALLOW_RUNTIME_VALIDATION=0
TRACKMASTER_JWT_SECRET=replace-with-at-least-32-random-bytes
TRACKMASTER_JWT_EXPIRES_IN=12h
TRACKMASTER_SESSION_COOKIE=tm_session
TRACKMASTER_SESSION_EXPIRES_IN_SECONDS=43200
# Validation-only Postgres runtime. Keep disabled in production.
# TRACKMASTER_ENABLE_POSTGRES_RUNTIME=I_UNDERSTAND_THIS_IS_VALIDATION_ONLY
# TRACKMASTER_POSTGRES_URL=postgresql://trackmaster_migrator:REPLACE_PASSWORD@127.0.0.1:5432/trackmaster_rehearsal
# TRACKMASTER_POSTGRES_POOL_MAX=5
# TRACKMASTER_ALLOW_UNSAFE_POSTGRES_RUNTIME=I_UNDERSTAND_THIS_COULD_TARGET_A_NON_REHEARSAL_DATABASE
TRACKMASTER_API_RATE_WINDOW_MS=60000
TRACKMASTER_API_RATE_LIMIT=240
TRACKMASTER_AUTH_RATE_WINDOW_MS=900000
TRACKMASTER_AUTH_RATE_LIMIT=20
# Optional for Vite dev on a separate origin. Leave empty in production.
CORS_ORIGIN=http://127.0.0.1:3000
VITE_TEST_MODE=false
